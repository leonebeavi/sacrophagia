<header class="sheet-header">
  <button type="button" class="profile-button" data-action="editImage" data-edit="img"
          data-tooltip="{{localize 'SACROPHAGIA.Sheet.EditImage'}}"
          aria-label="{{localize 'SACROPHAGIA.Sheet.EditImage'}}">
    <img class="profile" src="{{item.img}}" alt="{{item.name}}" />
  </button>
  <div class="identity">
    <input class="charname" type="text" name="name" value="{{item.name}}"
           placeholder="{{localize 'SACROPHAGIA.Sheet.Name'}}" />
    <span class="doc-type">{{localize (concat "TYPES.Item." item.type)}}</span>
  </div>
</header>
